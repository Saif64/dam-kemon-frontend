# STAGING — copy to .env.staging
# Build with: npm run build -- --mode staging
# (Vite uses .env.staging when --mode staging is passed)

# Point to the staging backend so the built bundle hits the staging API
# regardless of where it's hosted.
VITE_API_URL=https://staging-api.damkemon.com

# Optional: surface that we're in staging in the UI
VITE_ENV_LABEL=staging
