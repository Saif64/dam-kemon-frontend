# PRODUCTION — copy to .env.production
# Build with: npm run build (Vite uses .env.production by default in build mode)
# Or explicitly:  npm run build -- --mode production

# Point to the prod backend
VITE_API_URL=https://api.damkemon.com

# Optional: identifies the build for analytics / Sentry
VITE_ENV_LABEL=production

# Optional: a Sentry DSN, GA ID, Plausible domain, etc. as you wire them up
# VITE_SENTRY_DSN=
# VITE_GA_ID=
# VITE_PLAUSIBLE_DOMAIN=damkemon.com
